# Ignore all compiled Python files
*.pyc

# Ignore Python cache directories (very common)
__pycache__/

# Ignore virtual environments (never commit these!)
.venv/
venv/
env/

# Ignore Streamlit's local configuration/secrets if you have them
.streamlit/config.toml
.streamlit/secrets.toml

# Ignore generated local databases
data/*.db
data/*.db.download
data/*.db-shm
data/*.db-wal

# Test, coverage and local environment files
.pytest_cache/
.coverage
htmlcov/
.env
.env.*
!.env.example

# OS/editor output
.DS_Store
Thumbs.db
src/utilities/__pycache__/config_loader.cpython-311.pyc
src/etl/__pycache__/fetch_ons.cpython-311.pyc
src/etl/__pycache__/fetch_ons.cpython-311.pyc
src/utilities/__pycache__/config_loader.cpython-311.pyc
