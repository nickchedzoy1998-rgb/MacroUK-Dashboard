# Public HTTPS URL for the latest uploaded SQLite warehouse.
MACROUK_DATABASE_URL=https://example.invalid/economic_warehouse.db

# Optional local path override. Defaults to data/economic_warehouse.db.
# MACROUK_DATABASE_PATH=data/economic_warehouse.db

# Set to true for one process start when a fresh download must replace a valid local copy.
# MACROUK_FORCE_DATABASE_REFRESH=false
